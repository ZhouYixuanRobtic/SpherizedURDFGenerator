<?xml version='1.0' encoding='utf-8'?>
<robot name="fr3"
       xmlns:xacro="http://www.ros.org/wiki/xacro">


    <!-- macro -->
    <xacro:macro name="fr3"
                 params="id:='' prefix:='/home/zyx/pure_linux/ridgeback_dual_fr3/meshes' connected_with:='' xyz:='' rpy:=''">


        <!-- unless -->
        <xacro:unless value="${not connected_with}">
            <joint name="${id}_joint_${connected_with}" type="fixed">
                <parent link="${connected_with}"/>
                <child link="${id}_link0"/>
                <origin rpy="${rpy}" xyz="${xyz}"/>
            </joint>
        </xacro:unless>


        <!-- details of xacro /-->
        <link name="${id}_link0">
            <visual name="${id}_link0_visual">
                <geometry>
                    <mesh filename="${prefix}/fr3/visual/link0.dae"/>
                </geometry>
            </visual>
            <collision name="${id}_link0_collision">
                <geometry>
                    <mesh filename="${prefix}/fr3/collision/link0.stl"/>
                </geometry>
            </collision>
            <inertial>
                <origin rpy="0 0 0" xyz="-0.0172 0.0004 0.0745"/>
                <mass value="2.3966"/>
                <inertia ixx="0.009" ixy="0.0" ixz="0.002" iyy="0.0115" iyz="0.0" izz="0.0085"/>
            </inertial>
        </link>
        <!-- sub-link defining detailed meshes for collision with environment -->
        <link name="${id}_link1">
            <visual name="${id}_link1_visual">
                <geometry>
                    <mesh filename="${prefix}/fr3/visual/link1.dae"/>
                </geometry>
            </visual>
            <collision name="${id}_link1_collision">
                <geometry>
                    <mesh filename="${prefix}/fr3/collision/link1.stl"/>
                </geometry>
            </collision>
            <inertial>
                <origin rpy="0 0 0" xyz="0.0000004128 -0.0181251324 -0.0386035970"/>
                <mass value="2.9274653454"/>
                <inertia ixx="0.023927316485107913" ixy="1.3317903455714081e-05" ixz="-0.00011404774918616684"
                         iyy="0.0224821613275756" iyz="-0.0019950320628240115" izz="0.006350098258530016"/>
            </inertial>
        </link>
        <joint name="${id}_joint1" type="revolute">
            <origin rpy="0 0 0" xyz="0 0 0.333"/>
            <parent link="${id}_link0"/>
            <child link="${id}_link1"/>
            <axis xyz="0 0 1"/>
            <limit effort="87.0" lower="-2.7437" upper="2.7437" velocity="2.62"/>
            <safety_controller k_position="100.0" k_velocity="40.0" soft_lower_limit="-2.7437"
                               soft_upper_limit="2.7437"/>
            <dynamics D="1" K="7000" damping="0.003" friction="0.2" mu_coulomb="0" mu_viscous="16"/>
        </joint>
        <!-- sub-link defining detailed meshes for collision with environment -->
        <link name="${id}_link2">
            <visual name="${id}_link2_visual">
                <geometry>
                    <mesh filename="${prefix}/fr3/visual/link2.dae"/>
                </geometry>
            </visual>
            <collision name="${id}_link2_collision">
                <geometry>
                    <mesh filename="${prefix}/fr3/collision/link2.stl"/>
                </geometry>
            </collision>
            <inertial>
                <origin rpy="0 0 0" xyz="0.0031828864 -0.0743221644 0.0088146084"/>
                <mass value="2.9355370338"/>
                <inertia ixx="0.041938946257609425" ixy="0.00020257331521090626" ixz="0.004077784227179924"
                         iyy="0.02514514885014724" iyz="-0.0042252158006570156" izz="0.06170214472888839"/>
            </inertial>
        </link>
        <joint name="${id}_joint2" type="revolute">
            <origin rpy="-1.570796326794897 0 0" xyz="0 0 0"/>
            <parent link="${id}_link1"/>
            <child link="${id}_link2"/>
            <axis xyz="0 0 1"/>
            <limit effort="87.0" lower="-1.7837" upper="1.7837" velocity="2.62"/>
            <safety_controller k_position="100.0" k_velocity="40.0" soft_lower_limit="-1.7837"
                               soft_upper_limit="1.7837"/>
            <dynamics D="1" K="7000" damping="0.003" friction="0.2" mu_coulomb="0" mu_viscous="16"/>
        </joint>
        <!-- sub-link defining detailed meshes for collision with environment -->
        <link name="${id}_link3">
            <visual name="${id}_link3_visual">
                <geometry>
                    <mesh filename="${prefix}/fr3/visual/link3.dae"/>
                </geometry>
            </visual>
            <collision name="${id}_link3_collision">
                <geometry>
                    <mesh filename="${prefix}/fr3/collision/link3.stl"/>
                </geometry>
            </collision>
            <inertial>
                <origin rpy="0 0 0" xyz="0.0407015686 -0.0048200565 -0.0289730823"/>
                <mass value="2.2449013699"/>
                <inertia ixx="0.02410142547240885" ixy="0.002404694559042109" ixz="-0.002856269270114313"
                         iyy="0.01974053266708178" iyz="-0.002104212683891874" izz="0.019044494482244823"/>
            </inertial>
        </link>
        <joint name="${id}_joint3" type="revolute">
            <origin rpy="1.570796326794897 0 0" xyz="0 -0.316 0"/>
            <parent link="${id}_link2"/>
            <child link="${id}_link3"/>
            <axis xyz="0 0 1"/>
            <limit effort="87.0" lower="-2.9007" upper="2.9007" velocity="2.62"/>
            <safety_controller k_position="100.0" k_velocity="40.0" soft_lower_limit="-2.9007"
                               soft_upper_limit="2.9007"/>
            <dynamics D="1" K="7000" damping="0.003" friction="0.2" mu_coulomb="0" mu_viscous="16"/>
        </joint>
        <!-- sub-link defining detailed meshes for collision with environment -->
        <link name="${id}_link4">
            <visual name="${id}_link4_visual">
                <geometry>
                    <mesh filename="${prefix}/fr3/visual/link4.dae"/>
                </geometry>
            </visual>
            <collision name="${id}_link4_collision">
                <geometry>
                    <mesh filename="${prefix}/fr3/collision/link4.stl"/>
                </geometry>
            </collision>
            <inertial>
                <origin rpy="0 0 0" xyz="-0.0459100965 0.0630492960 -0.0085187868"/>
                <mass value="2.6155955791"/>
                <inertia ixx="0.03452998321913202" ixy="0.01322552265982813" ixz="0.01015142998484113"
                         iyy="0.028881621933049058" iyz="-0.0009762833870704552" izz="0.04125471171146641"/>
            </inertial>
        </link>
        <joint name="${id}_joint4" type="revolute">
            <origin rpy="1.570796326794897 0 0" xyz="0.0825 0 0"/>
            <parent link="${id}_link3"/>
            <child link="${id}_link4"/>
            <axis xyz="0 0 1"/>
            <limit effort="87.0" lower="-3.0421" upper="-0.1518" velocity="2.62"/>
            <safety_controller k_position="100.0" k_velocity="40.0" soft_lower_limit="-3.0421"
                               soft_upper_limit="-0.1518"/>
            <dynamics D="1" K="7000" damping="0.003" friction="0.2" mu_coulomb="0" mu_viscous="16"/>
        </joint>
        <!-- sub-link defining detailed meshes for collision with environment -->
        <link name="${id}_link5">
            <visual name="${id}_link5_visual">
                <geometry>
                    <mesh filename="${prefix}/fr3/visual/link5.dae"/>
                </geometry>
            </visual>
            <collision name="${id}_link5_collision">
                <geometry>
                    <mesh filename="${prefix}/fr3/collision/link5.stl"/>
                </geometry>
            </collision>
            <inertial>
                <origin rpy="0 0 0" xyz="-0.0016039605 0.0292536262 -0.0972965990"/>
                <mass value="2.3271207594"/>
                <inertia ixx="0.051610278463662895" ixy="-0.005715173387783472" ixz="-0.0035673167625872135"
                         iyy="0.04787729713371481" iyz="0.010673985108535986" izz="0.016423625579357254"/>
            </inertial>
        </link>
        <joint name="${id}_joint5" type="revolute">
            <origin rpy="-1.570796326794897 0 0" xyz="-0.0825 0.384 0"/>
            <parent link="${id}_link4"/>
            <child link="${id}_link5"/>
            <axis xyz="0 0 1"/>
            <limit effort="12.0" lower="-2.8065" upper="2.8065" velocity="5.26"/>
            <safety_controller k_position="100.0" k_velocity="40.0" soft_lower_limit="-2.8065"
                               soft_upper_limit="2.8065"/>
            <dynamics D="1" K="7000" damping="0.003" friction="0.2" mu_coulomb="0" mu_viscous="16"/>
        </joint>
        <!-- sub-link defining detailed meshes for collision with environment -->
        <link name="${id}_link6">
            <visual name="${id}_link6_visual">
                <geometry>
                    <mesh filename="${prefix}/fr3/visual/link6.dae"/>
                </geometry>
            </visual>
            <collision name="${id}_link6_collision">
                <geometry>
                    <mesh filename="${prefix}/fr3/collision/link6.stl"/>
                </geometry>
            </collision>
            <inertial>
                <origin rpy="0 0 0" xyz="0.0597131221 -0.0410294666 -0.0101692726"/>
                <mass value="1.8170376524"/>
                <inertia ixx="0.005412333594383447" ixy="0.006193456360285834" ixz="0.0014219289306117652"
                         iyy="0.014058329545509979" iyz="-0.0013140753741120031" izz="0.016080817924212554"/>
            </inertial>
        </link>
        <joint name="${id}_joint6" type="revolute">
            <origin rpy="1.570796326794897 0 0" xyz="0 0 0"/>
            <parent link="${id}_link5"/>
            <child link="${id}_link6"/>
            <axis xyz="0 0 1"/>
            <limit effort="12.0" lower="0.5445" upper="4.5169" velocity="4.18"/>
            <safety_controller k_position="100.0" k_velocity="40.0" soft_lower_limit="0.5445"
                               soft_upper_limit="4.5169"/>
            <dynamics D="1" K="7000" damping="0.003" friction="0.2" mu_coulomb="0" mu_viscous="16"/>
        </joint>
        <!-- sub-link defining detailed meshes for collision with environment -->
        <link name="${id}_link7">
            <visual name="${id}_link7_visual">
                <geometry>
                    <mesh filename="${prefix}/fr3/visual/link7.dae"/>
                </geometry>
            </visual>
            <collision name="${id}_link7_collision">
                <geometry>
                    <mesh filename="${prefix}/fr3/collision/link7.stl"/>
                </geometry>
            </collision>
            <inertial>
                <origin rpy="0 0 0" xyz="0.0045225817 0.0086261921 -0.0161633251"/>
                <mass value="0.6271432862"/>
                <inertia ixx="0.00021092389150104718" ixy="-2.433299114461931e-05" ixz="4.564480393778983e-05"
                         iyy="0.00017718568002411474" iyz="8.744070223226438e-05" izz="5.993190599659971e-05"/>
            </inertial>
        </link>
        <joint name="${id}_joint7" type="revolute">
            <origin rpy="1.570796326794897 0 0" xyz="0.088 0 0"/>
            <parent link="${id}_link6"/>
            <child link="${id}_link7"/>
            <axis xyz="0 0 1"/>
            <limit effort="12.0" lower="-3.0159" upper="3.0159" velocity="5.26"/>
            <safety_controller k_position="100.0" k_velocity="40.0" soft_lower_limit="-3.0159"
                               soft_upper_limit="3.0159"/>
            <dynamics D="1" K="7000" damping="0.003" friction="0.2" mu_coulomb="0" mu_viscous="16"/>
        </joint>
        <link name="${id}_link8"/>
        <joint name="${id}_joint8" type="fixed">
            <origin rpy="0 0 0" xyz="0 0 0.107"/>
            <parent link="${id}_link7"/>
            <child link="${id}_link8"/>
        </joint>

    </xacro:macro>
</robot>
