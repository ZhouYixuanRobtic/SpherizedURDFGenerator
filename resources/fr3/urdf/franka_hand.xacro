<?xml version='1.0' encoding='utf-8'?>
<robot name="franka_hand"
       xmlns:xacro="http://www.ros.org/wiki/xacro">


    <!-- macro -->
    <xacro:macro name="franka_hand" params="id:='' prefix:='/home/zyx/pure_linux/ridgeback_dual_fr3/meshes' connected_with:='' xyz:='' rpy:=''">


        <xacro:unless value="${not connected_with}">
            <joint name="${id}_joint_${connected_with}" type="fixed">
                <parent link="${connected_with}"/>
                <child link="${id}_hand"/>
                <origin rpy="${rpy}" xyz="${xyz}"/>
            </joint>
        </xacro:unless>


        <link name="${id}_hand">
            <visual name="${id}_hand_visual">
                <geometry>
                    <mesh filename="${prefix}/franka_hand/visual/hand.dae"/>
                </geometry>
            </visual>
            <collision name="${id}_hand_collision">
                <geometry>
                    <mesh filename="${prefix}/franka_hand/collision/hand.stl"/>
                </geometry>
            </collision>
            <inertial>
                <origin rpy="0 0 0" xyz="-0.0000376 0.0119128 0.0207260"/>
                <mass value="0.6544"/>
                <inertia ixx="0.00186" ixy="0.0" ixz="0.0" iyy="0.0003" iyz="-2e-05" izz="0.00174"/>
            </inertial>
        </link>
        
        <!-- Define the hand_tcp frame -->
        <link name="${id}_hand_tcp"/>
        <joint name="${id}_hand_tcp_joint" type="fixed">
            <origin rpy="0 0 0" xyz="0 0 0.1034"/>
            <parent link="${id}_hand"/>
            <child link="${id}_hand_tcp"/>
        </joint>
        <link name="${id}_leftfinger">
            <visual name="${id}_leftfinger_visual">
            <origin rpy="-1.57079632679 0.20245819348 -1.57079632679" xyz="-0.0165 0.0165 0.12773331296"/>
                <geometry>
                    <mesh filename="${prefix}/plate/collision/flex_griper_connect.stl"/>
                </geometry>
            </visual>
            <!-- screw mount -->
            <collision name="${id}_leftfinger_collision">
            <origin rpy="-1.57079632679 0.20245819348 -1.57079632679" xyz="-0.0165 0.0165 0.12773331296"/>
                <geometry>
                    <mesh filename="${prefix}/plate/collision/flex_griper_connect.stl"/>
                </geometry>
            </collision>
            <inertial>
                <origin rpy="0 0 0" xyz="0 0.0145644 0.0227941"/>
                <mass value="0.1"/>
                <inertia ixx="3.01220925051e-05" ixy="0.0" ixz="0.0" iyy="2.95873808038e-05" iyz="0.0" izz="6.95125211657e-06"/>
            </inertial>
        </link>
        <link name="${id}_rightfinger">
            <visual name="${id}_rightfinger_visual">
                <origin rpy="-1.57079632679 0.20245819348 -1.57079632679" xyz="-0.0165 0.0165 0.12773331296"/>
                <geometry>
                    <mesh filename="${prefix}/plate/collision/flex_griper_connect.stl"/>
                </geometry>
            </visual>
            <collision name="${id}_rightfinger_collision">
                <origin rpy="-1.57079632679 0.20245819348 -1.57079632679" xyz="-0.0165 0.0165 0.12773331296"/>
                <geometry>
                    <mesh filename="${prefix}/plate/collision/flex_griper_connect.stl"/>
                </geometry>
            </collision>
            <inertial>
                <origin rpy="0 0 3.141592653589793" xyz="0 0.0145644 0.0227941"/>
                <mass value="0.1"/>
                <inertia ixx="3.01220925051e-05" ixy="0.0" ixz="0.0" iyy="2.95873808038e-05" iyz="0.0" izz="6.95125211657e-06"/>
            </inertial>
        </link>
        <joint name="${id}_finger_joint1" type="prismatic">
            <parent link="${id}_hand"/>
            <child link="${id}_leftfinger"/>
            <origin rpy="0 0 0" xyz="0 0 0.0584"/>
            <axis xyz="0 1 0"/>
            <limit effort="100" lower="0.0" upper="0.04" velocity="0.2"/>
            <dynamics damping="0.3"/>
        </joint>
        <joint name="${id}_finger_joint2" type="prismatic">
            <parent link="${id}_hand"/>
            <child link="${id}_rightfinger"/>
            <origin rpy="0 0 3.141592653589793" xyz="0 0 0.0584"/>
            <axis xyz="0 1 0"/>
            <limit effort="100" lower="0.0" upper="0.04" velocity="0.2"/>
            <mimic joint="${id}_finger_joint1" multiplier="1" offset="0"/>
            <dynamics damping="0.3"/>
        </joint>

    </xacro:macro>
</robot>
