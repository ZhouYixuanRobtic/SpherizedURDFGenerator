<?xml version='1.0' encoding='utf-8'?>
<robot name="elbow_tube">
  <link name="world" />
  <link name="elbow_tube">
    <visual>
      <geometry>
        <mesh filename="../meshes/elbow_tube.obj" scale="1 1 1" />
      </geometry>
    </visual>
    <collision>
      <geometry>
        <mesh filename="../meshes/elbow_tube.obj" scale="1 1 1" />
      </geometry>
    </collision>
  </link>
  <joint name="joint_world_elbow_tube" type="fixed">
    <parent link="world" />
    <child link="elbow_tube" />
    <origin xyz="0 0 0" rpy="0 0 0" />
  </joint>
</robot>